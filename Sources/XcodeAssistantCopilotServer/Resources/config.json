{
  "mcpServers": {
    "xcode": {
      "type": "local",
      "command": "xcrun",
      "args": ["mcpbridge"],
      "allowedTools": ["*"]
    }
  },
  "allowedCliTools": [],
  "bodyLimitMiB": 4,
  "excludedFilePatterns": [],
  "reasoningEffort": "xhigh",
  "autoApprovePermissions": ["read", "mcp"],
  "timeouts": {
    "requestTimeoutSeconds": 300,
    "streamingEndpointTimeoutSeconds": 300,
    "defaultEndpointTimeoutSeconds": 60,
    "httpClientTimeoutSeconds": 300
  }
}
